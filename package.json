{
  "name": "v-market-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "db:seed": "npx tsx apps/web/src/utils/run-seed.ts"
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "mongodb": "^6.21.0"
  }
}
