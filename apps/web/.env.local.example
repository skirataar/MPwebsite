# V-Market India — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── PostgreSQL (required) ───────────────────────────────────────
# Neon.tech (recommended): https://neon.tech  → New project → copy connection string
# Supabase: https://supabase.com → Settings → Database → Connection string (URI mode)
# Local Docker: postgresql://postgres:password@localhost:5432/vmarket
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vmarket?sslmode=require"

# ─── Clerk Auth (required) ───────────────────────────────────────
# Sign up free at https://clerk.com → Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URLs (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ─── Razorpay Payments (optional, for checkout) ──────────────────
# Sign up at https://razorpay.com → Settings → API Keys → Test mode
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# ─── Mux Video (optional, for real video uploads) ────────────────
# Sign up at https://mux.com → Settings → Access Tokens
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
